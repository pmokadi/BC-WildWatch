{
  "name": "bc-wildwatch",
  "version": "1.0.0",
  "description": "Campus wildlife safety reporting and AI-powered species detection — Belgium Campus iTversity",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
